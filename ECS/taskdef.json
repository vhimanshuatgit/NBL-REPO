{
    "executionRoleArn": "arn:aws:iam::246217239674:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "himginx",
            "image": "IMAGE1_NAME",
            "essential": true,
            "portMappings": [
                {
                    "hostPort": 0,
                    "protocol": "tcp",
                    "containerPort": 80
                }
            ]
        }
    ],
    "requiresCompatibilities": [
        "EC2"
    ],
    "networkMode": "bridge",
    "cpu": "256",
    "memory": "256",
    "family": "HimNginx"
}
